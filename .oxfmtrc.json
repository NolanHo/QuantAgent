{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "plugins": ["typescript", "jsx"],
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "bracketSpacing": true,
    "arrowParens": "always"
  }
}