{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantagent.local/schemas/model-invocation-provider-v1.schema.json",
  "title": "Model Invocation Provider V1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": ["integer", "null"]
    },
    "provider_id": {
      "type": ["integer", "null"]
    },
    "provider_type": {
      "const": "openai_compatible"
    },
    "provider_name": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "preset_key": {
      "type": ["string", "null"],
      "enum": ["global_default", "economy_text", "general_text", "reasoning_text", "multimodal", null]
    },
    "status": {
      "enum": ["succeeded", "failed"]
    },
    "token_usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prompt_tokens": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "completion_tokens": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "total_tokens": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      },
      "required": ["prompt_tokens", "completion_tokens", "total_tokens"]
    },
    "error_summary": {
      "type": ["string", "null"]
    },
    "request_id": {
      "type": ["string", "null"]
    },
    "trace_id": {
      "type": ["string", "null"]
    },
    "agent_run_id": {
      "type": ["string", "null"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "provider_id",
    "provider_type",
    "provider_name",
    "model",
    "preset_key",
    "status",
    "token_usage",
    "error_summary",
    "request_id",
    "trace_id",
    "agent_run_id",
    "created_at"
  ]
}
