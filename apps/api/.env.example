# apps/api 本地环境变量示例。
# apps/api/.env 会覆盖仓库根目录 .env 中的重复变量。
# 真实进程环境变量仍是最高优先级；不要提交复制后的真实 .env 文件。

APP_ENV=local
DATABASE_URL=postgresql+psycopg://quantagent:quantagent@localhost:15432/quantagent
# 留空时默认探测到仓库根 runtime；非空相对路径仍按当前进程 cwd 解析。
# 生产或容器环境建议显式改成持久卷路径。
RUNTIME_DIR=
LOG_LEVEL=INFO
EVENT_BUS_BACKEND=kafka
EVENT_BUS_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:19092
EVENT_BUS_KAFKA_CLIENT_ID=quantagent-local
EVENT_BUS_KAFKA_DEFAULT_GROUP_ID=quantagent-worker
EVENT_BUS_TOPIC_PREFIX=
LOG_DIR=
LOG_INSTANCE_ID=api-local
LOG_ROTATE_MAX_BYTES=20971520
LOG_QUEUE_MAX_SIZE=10000
LOG_ACCESS_DROP_WHEN_FULL=true
LOG_ACCESS_RETENTION_DAYS=3
LOG_APP_RETENTION_DAYS=14
LOG_ERROR_RETENTION_DAYS=30
LOG_SECURITY_RETENTION_DAYS=30
LOG_AUDIT_RETENTION_DAYS=90
LOG_MAINTENANCE_MIN_AGE_SECONDS=300
LOG_MAX_TOTAL_BYTES=
LOG_MIN_FREE_BYTES=

# API 本地开发监听地址。
API_HOST=127.0.0.1
API_PORT=8000
API_V1_PREFIX=/api/v1

# API 本地单用户鉴权配置。
AUTH_ENABLED=true
AUTH_ADMIN_PASSWORD=12345678
AUTH_SESSION_SECRET=dev-session-secret-change-me
AUTH_COOKIE_NAME=quantagent_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_SESSION_LIFETIME_SECONDS=43200
AUTH_SESSION_ABSOLUTE_LIFETIME_SECONDS=86400
AUTH_SESSION_REFRESH_THRESHOLD_SECONDS=1800
AUTH_CSRF_HEADER_NAME=X-CSRF-Token

# 模型 provider API key 入库加密主密钥；本地可用 `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"` 生成。
MODEL_CONFIG_ENCRYPTION_KEY=12345678901234567890123456789012345678901234567890123456789012345

# Notification ingress / dispatch。API 只承载 ingress HTTP host；dispatch 由 worker 消费 notification.requested。
NOTIFICATION_INGRESS_ENABLED=false
NOTIFICATION_INGRESS_PLUGIN_ID=
NOTIFICATION_INGRESS_PLUGIN_CONFIG={}
NOTIFICATION_DISPATCH_ENABLED=true
NOTIFICATION_DISPATCH_PLUGIN_ID=quantagent.official.notification.discord
NOTIFICATION_DISPATCH_CHANNEL=discord
