# apps/api test 环境示例。
# 复制为 apps/api/.env.test；只放测试安全值，不提交真实 secret。

APP_ENV=test
DATABASE_URL=sqlite+pysqlite:///:memory:
# 测试如需稳定复用仓库根 runtime，可留空；如需隔离，可显式写相对路径。
RUNTIME_DIR=./runtime
LOG_LEVEL=WARNING
LOG_DIR=
LOG_INSTANCE_ID=api-test
LOG_ROTATE_MAX_BYTES=1048576
LOG_QUEUE_MAX_SIZE=512
LOG_ACCESS_DROP_WHEN_FULL=true
LOG_ACCESS_RETENTION_DAYS=1
LOG_APP_RETENTION_DAYS=1
LOG_ERROR_RETENTION_DAYS=3
LOG_SECURITY_RETENTION_DAYS=3
LOG_AUDIT_RETENTION_DAYS=7
LOG_MAINTENANCE_MIN_AGE_SECONDS=1
LOG_MAX_TOTAL_BYTES=
LOG_MIN_FREE_BYTES=

AUTH_ENABLED=false
AUTH_ADMIN_PASSWORD=12345678
AUTH_SESSION_SECRET=dev-session-secret-change-me
