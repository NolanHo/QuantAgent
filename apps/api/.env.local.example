# apps/api 本机私有覆盖示例。
# 复制为 apps/api/.env.local 后按本机需要修改；真实 .env.local 不提交。

APP_ENV=local
LOG_LEVEL=DEBUG
# 留空时默认探测到仓库根 runtime；本机如需按 cwd 隔离，可显式写 ./runtime-dev。
RUNTIME_DIR=
LOG_DIR=
LOG_INSTANCE_ID=api-local-dev
LOG_ROTATE_MAX_BYTES=10485760
LOG_QUEUE_MAX_SIZE=2000
LOG_ACCESS_DROP_WHEN_FULL=true
LOG_ACCESS_RETENTION_DAYS=3
LOG_APP_RETENTION_DAYS=7
LOG_ERROR_RETENTION_DAYS=14
LOG_SECURITY_RETENTION_DAYS=14
LOG_AUDIT_RETENTION_DAYS=30
LOG_MAINTENANCE_MIN_AGE_SECONDS=300
LOG_MAX_TOTAL_BYTES=
LOG_MIN_FREE_BYTES=

API_HOST=127.0.0.1
API_PORT=8000
AUTH_ENABLED=true
