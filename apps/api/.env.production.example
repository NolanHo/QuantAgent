# apps/api production 环境示例。
# 复制为 apps/api/.env.production；不要把真实生产 secret 或数据库地址提交到仓库。
# 生产 secret 必须来自进程环境、CI/deployment secret、挂载 secret 文件或未来 Secret Manager。

APP_ENV=production
DATABASE_URL=postgresql+psycopg://change-me:change-me@db:5432/quantagent
RUNTIME_DIR=/app/runtime
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
AUTH_ENABLED=true
AUTH_ADMIN_PASSWORD=change-me
AUTH_SESSION_SECRET=change-me
AUTH_COOKIE_SECURE=true
