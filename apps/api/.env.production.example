# apps/api production 环境示例。
# 复制为 apps/api/.env.production；不要把真实生产 secret 或数据库地址提交到仓库。
# 生产 secret 必须来自进程环境、CI/deployment secret、挂载 secret 文件或未来 Secret Manager。

APP_ENV=production
DATABASE_URL=postgresql+psycopg://change-me:change-me@db:5432/quantagent
# 生产环境建议显式指向持久卷；如需覆盖日志目录，可单独设置 LOG_DIR。
RUNTIME_DIR=/app/runtime
LOG_LEVEL=INFO
LOG_DIR=
LOG_INSTANCE_ID=api-production
LOG_ROTATE_MAX_BYTES=20971520
LOG_QUEUE_MAX_SIZE=10000
LOG_ACCESS_DROP_WHEN_FULL=true
LOG_ACCESS_RETENTION_DAYS=3
LOG_APP_RETENTION_DAYS=14
LOG_ERROR_RETENTION_DAYS=30
LOG_SECURITY_RETENTION_DAYS=30
LOG_AUDIT_RETENTION_DAYS=90
LOG_MAINTENANCE_MIN_AGE_SECONDS=300
LOG_MAX_TOTAL_BYTES=
LOG_MIN_FREE_BYTES=

API_HOST=0.0.0.0
API_PORT=8000
AUTH_ENABLED=true
AUTH_ADMIN_PASSWORD=change-me
AUTH_SESSION_SECRET=change-me
AUTH_COOKIE_SECURE=true
