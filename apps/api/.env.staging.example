# apps/api staging 环境示例。
# 复制为 apps/api/.env.staging；真实 secret 应来自进程环境、CI/deployment secret 或未来 Secret Manager。

APP_ENV=staging
DATABASE_URL=postgresql+psycopg://change-me:change-me@db:5432/quantagent
RUNTIME_DIR=/app/runtime
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
AUTH_ENABLED=true
AUTH_ADMIN_PASSWORD=change-me
AUTH_SESSION_SECRET=change-me
AUTH_COOKIE_SECURE=true
