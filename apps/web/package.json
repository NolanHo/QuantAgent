{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint .",
    "test:browser:install": "playwright install chromium",
    "test:browser:install:deps": "playwright install --with-deps chromium",
    "test:ct": "playwright test --config=playwright-ct.config.ts --project=chromium-ct",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "node ./scripts/run-playwright-e2e.mjs",
    "test:e2e:debug": "node ./scripts/run-playwright-e2e.mjs --debug",
    "test:e2e:ui": "node ./scripts/run-playwright-e2e.mjs --ui",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@heroui/react": "^3.0.4",
    "@heroui/styles": "^3.0.4",
    "@heroui/system": "^2.4.28",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.169.2",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.554.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/experimental-ct-react": "^1.55.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.35",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
