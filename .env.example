# 共享应用环境，例如 local/staging/production。
APP_ENV=local

# 宿主机侧数据库连接串，供本地工具使用；示例端口避开本机 5432。
DATABASE_URL=postgresql+psycopg://quantagent:quantagent@localhost:15432/quantagent

# 容器侧数据库连接串，供 docker-compose.yml 中的 API 服务使用。
API_DATABASE_URL=postgresql+psycopg://quantagent:quantagent@db:5432/quantagent

# 容器侧数据库连接串，供一次性迁移服务使用。
MIGRATION_DATABASE_URL=postgresql+psycopg://quantagent:quantagent@db:5432/quantagent

# 宿主机侧运行时目录，供容器外本地进程使用。
RUNTIME_DIR=./runtime

# 应用日志级别，例如 DEBUG/INFO/WARNING/ERROR。
LOG_LEVEL=INFO

# API 发布到宿主机的地址和端口；容器内固定监听 8000。
API_HOST=0.0.0.0
API_BIND_HOST=127.0.0.1
API_PORT=8000

# API 容器内运行时目录。
API_RUNTIME_DIR=/app/runtime

# Compose db 服务发布到宿主机的地址和端口。
DB_HOST=127.0.0.1
DB_PORT=15432

# Compose db 服务使用的本地 PostgreSQL 配置。
POSTGRES_DB=quantagent
POSTGRES_USER=quantagent
POSTGRES_PASSWORD=quantagent

# Web 前端本地默认运行时配置；缺省时会回退到测试安全值。
VITE_API_BASE_URL=
VITE_WEBSOCKET_URL=
VITE_AUTH_ENABLED=false
