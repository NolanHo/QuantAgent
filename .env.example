# 共享应用环境默认值，例如 local/staging/production。
# API 进程会先读这里，再读 apps/api/.env 和 apps/api/.env.<APP_ENV>。
# API 专属重复变量应放在 apps/api/.env*，真实进程环境变量仍最高优先级。
APP_ENV=local

# 宿主机侧数据库连接串，供 `uv run api`、`uv run worker`、`uv run scheduler`
# 和 `uv run db ...` 这类本地直跑命令使用；示例端口避开本机 5432。
DATABASE_URL=postgresql+psycopg://quantagent:quantagent@127.0.0.1:15432/quantagent

# Compose 容器内部数据库连接串，供 `api`、`worker`、`scheduler`、`migrate` 服务使用。
COMPOSE_DATABASE_URL=postgresql+psycopg://quantagent:quantagent@db:5432/quantagent

# 宿主机侧运行时目录，供容器外本地进程使用。
RUNTIME_DIR=./runtime

# Compose 容器内部运行时目录。
COMPOSE_RUNTIME_DIR=/app/runtime

# 应用日志级别，例如 DEBUG/INFO/WARNING/ERROR。
LOG_LEVEL=INFO

# Event Bus 运行默认使用 Kafka；测试或单进程 smoke 才显式覆盖为 memory。
EVENT_BUS_BACKEND=kafka
EVENT_BUS_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:19092
EVENT_BUS_KAFKA_CLIENT_ID=quantagent-local
EVENT_BUS_KAFKA_DEFAULT_GROUP_ID=quantagent-worker
# worker 会执行 Readability 和模型调用，Kafka consumer 超时不能按纯轻量消息处理配置。
EVENT_BUS_KAFKA_SESSION_TIMEOUT_MS=120000
EVENT_BUS_KAFKA_HEARTBEAT_INTERVAL_MS=3000
EVENT_BUS_KAFKA_MAX_POLL_INTERVAL_MS=900000
EVENT_BUS_KAFKA_CONSUMER_CONCURRENCY=10
EVENT_BUS_TOPIC_PREFIX=

# Scheduler 轮询配置。空 tick 日志会按 idle interval 节流，避免每次轮询刷无意义日志。
SCHEDULER_POLL_INTERVAL_SECONDS=5
SCHEDULER_DUE_LIMIT=100
SCHEDULER_RUN_TIMEOUT_MS=30000
SCHEDULER_IDLE_LOG_INTERVAL_SECONDS=60

# Worker 对 legacy batch 消息内的多篇文章也做受控并发；普通单篇消息并发由 EVENT_BUS_KAFKA_CONSUMER_CONCURRENCY 控制。
WORKER_ARTICLE_CONCURRENCY=10

# Compose 容器内部 Kafka bootstrap servers；本地跨进程链路建议直接用这个默认值。
COMPOSE_EVENT_BUS_KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# 模型 provider API key 入库加密主密钥；本地可用 `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"` 生成。
MODEL_CONFIG_ENCRYPTION_KEY=

# API 发布到宿主机的地址和端口；API 容器内固定监听 0.0.0.0:8000。
API_BIND_HOST=127.0.0.1
API_PORT=8000

# Compose db 服务发布到宿主机的地址和端口。
DB_HOST=127.0.0.1
DB_PORT=15432

# Compose db 服务使用的本地 PostgreSQL 配置。
POSTGRES_IMAGE=postgres:17-alpine
POSTGRES_DB=quantagent
POSTGRES_USER=quantagent
POSTGRES_PASSWORD=quantagent

# Compose Kafka 服务镜像。Apache Kafka 当前没有官方 alpine tag；如需替换可在本地 .env 覆盖。
KAFKA_IMAGE=apache/kafka-native:4.0.0

# Web 前端本地默认运行时配置；`bun run --cwd apps/web dev` 默认通过 Vite proxy 走 `127.0.0.1:8000`，
# 所以这里留空即可；如果前后端不在同源下运行，再显式填写。
VITE_API_BASE_URL=
VITE_WEBSOCKET_URL=
VITE_AUTH_ENABLED=false

# API Cookie Session 默认超时配置。
AUTH_SESSION_LIFETIME_SECONDS=43200
AUTH_SESSION_ABSOLUTE_LIFETIME_SECONDS=86400
AUTH_SESSION_REFRESH_THRESHOLD_SECONDS=1800

# Notification ingress HTTP host，本地默认关闭。
NOTIFICATION_INGRESS_ENABLED=false
NOTIFICATION_INGRESS_PLUGIN_ID=
NOTIFICATION_INGRESS_PLUGIN_CONFIG={}

# Notification dispatcher 由 worker 消费 notification.requested 时读取；默认关闭，避免本地误发外部通知。
NOTIFICATION_DISPATCH_ENABLED=false
NOTIFICATION_DISPATCH_PLUGIN_ID=quantagent.official.notification.discord
NOTIFICATION_DISPATCH_PLUGIN_CONFIG={}
NOTIFICATION_DISPATCH_CHANNEL=discord
