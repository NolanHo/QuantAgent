# 共享应用环境默认值，例如 local/staging/production。
# API 进程会先读这里，再读 apps/api/.env 和 apps/api/.env.<APP_ENV>。
# API 专属重复变量应放在 apps/api/.env*，真实进程环境变量仍最高优先级。
APP_ENV=local

# 宿主机侧数据库连接串，供本地工具和非 API 入口使用；示例端口避开本机 5432。
DATABASE_URL=postgresql+psycopg://quantagent:quantagent@localhost:15432/quantagent

# 容器侧数据库连接串，供一次性迁移服务使用。
MIGRATION_DATABASE_URL=postgresql+psycopg://quantagent:quantagent@db:5432/quantagent

# 宿主机侧运行时目录；留空时 API 会默认探测到仓库根 runtime。
# 非空相对路径仍按当前进程 cwd 解析；生产建议显式指向持久卷。
RUNTIME_DIR=

# 应用日志级别，例如 DEBUG/INFO/WARNING/ERROR。
LOG_LEVEL=INFO

# Event Bus 默认使用内存 backend；需要真实 Kafka 时显式切换为 kafka。
EVENT_BUS_BACKEND=memory
EVENT_BUS_KAFKA_BOOTSTRAP_SERVERS=
EVENT_BUS_KAFKA_CLIENT_ID=quantagent-local
EVENT_BUS_KAFKA_DEFAULT_GROUP_ID=quantagent-worker
EVENT_BUS_TOPIC_PREFIX=

# 模型 provider API key 入库加密主密钥；本地可用 `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"` 生成。
MODEL_CONFIG_ENCRYPTION_KEY=

# API 结构化文件日志默认写入 RUNTIME_DIR/logs/api；
# 当 LOG_DIR 和 RUNTIME_DIR 都留空时，API 默认落到仓库根 runtime/logs/api。
LOG_DIR=
LOG_INSTANCE_ID=api-local
LOG_ROTATE_MAX_BYTES=20971520
LOG_QUEUE_MAX_SIZE=10000
LOG_ACCESS_DROP_WHEN_FULL=true
LOG_ACCESS_RETENTION_DAYS=3
LOG_APP_RETENTION_DAYS=14
LOG_ERROR_RETENTION_DAYS=30
LOG_SECURITY_RETENTION_DAYS=30
LOG_AUDIT_RETENTION_DAYS=90
LOG_MAINTENANCE_MIN_AGE_SECONDS=300
LOG_MAX_TOTAL_BYTES=
LOG_MIN_FREE_BYTES=

# API 发布到宿主机的地址和端口；API 容器内固定监听 0.0.0.0:8000。
API_BIND_HOST=127.0.0.1
API_PORT=8000

# Compose db 服务发布到宿主机的地址和端口。
DB_HOST=127.0.0.1
DB_PORT=15432

# Compose db 服务使用的本地 PostgreSQL 配置。
POSTGRES_DB=quantagent
POSTGRES_USER=quantagent
POSTGRES_PASSWORD=quantagent

# Web 前端本地默认运行时配置；缺省时会回退到测试安全值。
VITE_API_BASE_URL=
VITE_WEBSOCKET_URL=
VITE_AUTH_ENABLED=false

# API Cookie Session 默认超时配置。
AUTH_SESSION_LIFETIME_SECONDS=43200
AUTH_SESSION_ABSOLUTE_LIFETIME_SECONDS=86400
AUTH_SESSION_REFRESH_THRESHOLD_SECONDS=1800

# Discord interaction webhook ingress，本地默认关闭。
DISCORD_INTERACTIONS_ENABLED=false
DISCORD_INTERACTIONS_PLUGIN_ID=quantagent.official.notification.discord
DISCORD_INTERACTIONS_PUBLIC_KEY=
DISCORD_INTERACTIONS_RESPONSE_TEXT="QuantAgent received your Discord interaction."
DISCORD_INTERACTIONS_TIMESTAMP_TOLERANCE_SECONDS=300
DISCORD_INTERACTIONS_GUILD_ALLOWLIST=
DISCORD_INTERACTIONS_CHANNEL_ALLOWLIST=
