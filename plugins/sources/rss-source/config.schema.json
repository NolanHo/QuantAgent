{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RSS Source Config",
  "type": "object",
  "properties": {
    "feeds": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri",
        "pattern": "^https?://",
        "minLength": 1
      },
      "minItems": 1,
      "maxItems": 20
    },
    "timeout_seconds": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 30,
      "default": 10
    },
    "headers": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "string"
      },
      "default": {},
      "description": "Non-sensitive public request headers only. Authorization, Cookie, and API-key style headers are not allowed here."
    },
    "user_agent": {
      "type": "string",
      "minLength": 1,
      "default": "QuantAgentRSSSource/0.1"
    },
    "max_items_per_feed": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 20
    },
    "max_response_bytes": {
      "type": "integer",
      "minimum": 1024,
      "maximum": 1048576,
      "default": 262144
    },
    "max_content_chars": {
      "type": "integer",
      "minimum": 128,
      "maximum": 20000,
      "default": 4000
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "maxItems": 50
    },
    "include_content": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "feeds"
  ],
  "additionalProperties": false
}
