{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Readability Link Reader Config",
  "type": "object",
  "properties": {
    "url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://",
      "minLength": 1
    },
    "headers": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    },
    "timeout_seconds": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 30,
      "default": 10
    },
    "min_text_length": {
      "type": "integer",
      "minimum": 0,
      "default": 140
    }
  },
  "required": [
    "url"
  ],
  "additionalProperties": false
}
