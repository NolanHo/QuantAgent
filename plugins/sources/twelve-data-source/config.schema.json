{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Twelve Data Quote Source Plugin Config",
  "type": "object",
  "properties": {
    "symbols": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "maxItems": 50,
      "description": "要拉取最新报价的股票代码列表，例如 [\"AAPL\", \"MSFT\", \"0700.HK\"]"
    },
    "market": {
      "type": "string",
      "description": "可选的市场标识，例如 \"NYSE\"、\"NASDAQ\"、\"HKEX\""
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 30,
      "default": 10,
      "description": "单次 API 调用超时秒数"
    }
  },
  "required": ["symbols"],
  "additionalProperties": false
}