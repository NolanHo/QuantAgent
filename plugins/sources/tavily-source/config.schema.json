{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tavily Source Tool Config",
  "type": "object",
  "properties": {
    "api_key": {
      "type": "string",
      "description": "Tavily API key. The platform stores it encrypted and injects it before plugin load.",
      "sensitive": true,
      "minLength": 1
    },
    "timeout_seconds": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 30,
      "default": 10
    },
    "default_max_results": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 5
    },
    "default_search_depth": {
      "type": "string",
      "enum": ["basic", "advanced"],
      "default": "basic"
    },
    "include_favicon": {
      "type": "boolean",
      "default": false
    },
    "include_raw_content": {
      "type": "boolean",
      "default": false
    }
  },
  "required": ["api_key"],
  "additionalProperties": false
}
